# Supabase — get these from your Supabase project dashboard → Project Settings → API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key-here

# The public URL this app is hosted at (used for Supabase auth redirect emails)
# Local development:
VITE_APP_BASE_URL=http://localhost:5173
# Production (set this in Vercel environment variables):
# VITE_APP_BASE_URL=https://timebox.athuljacob.com

# ─── Google Integrations (Gmail + Google Calendar) ───────────────────────────
# Create an OAuth 2.0 Client ID in Google Cloud Console → APIs & Services → Credentials
# Application type: "Web application"
# Authorised JavaScript origins: http://localhost:5173 (dev) + https://timebox.athuljacob.com (prod)
# Authorised redirect URIs:
#   http://localhost:5173/auth/google/callback      (dev)
#   https://timebox.athuljacob.com/auth/google/callback  (prod)
#
# Enable APIs: Gmail API + Google Calendar API in the same project.
#
# IMPORTANT: NEVER put GOOGLE_CLIENT_SECRET in any VITE_ variable — it must stay server-side only.
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
VITE_GOOGLE_REDIRECT_URI=http://localhost:5173/auth/google/callback
# Production (set in Vercel):
# VITE_GOOGLE_CLIENT_ID=your-production-client-id.apps.googleusercontent.com
# VITE_GOOGLE_REDIRECT_URI=https://timebox.athuljacob.com/auth/google/callback
